# 🔒 CONFIGURATION D'ENVIRONNEMENT - NDIYE FRONTEND
# Copiez ce fichier vers .env et remplissez les valeurs appropriées
# ⚠️ NE JAMAIS COMMITTER LE FICHIER .env AVEC DES VRAIES VALEURS

# =============================================================================
# 🌐 CONFIGURATION SERVEUR
# =============================================================================

# URL de l'API backend
API_URL=http://192.168.1.5:3001

# URL de l'application frontend
APP_URL=http://localhost:4200

# Environnement d'exécution
NODE_ENV=development

# =============================================================================
# 💳 CONFIGURATION PAIEMENTS
# =============================================================================

# Clé publique Stripe (TEST - remplacer par la vraie clé)
# ⚠️ ATTENTION: Révoquer l'ancienne clé exposée et générer une nouvelle
STRIPE_PUBLIC_KEY=pk_test_VOTRE_NOUVELLE_CLE_PUBLIQUE_ICI

# =============================================================================
# 📱 CONFIGURATION MOBILE/IONIC
# =============================================================================

# Port du serveur de développement Ionic
IONIC_DEV_SERVER_PORT=8100

# Adresse IP pour le développement mobile
MOBILE_DEV_IP=192.168.1.5

# =============================================================================
# 🔧 CONFIGURATION DÉVELOPPEMENT
# =============================================================================

# Activer les logs de debug
DEBUG_MODE=true

# Activer le Hot Module Replacement
HMR_ENABLED=true

# Niveau de logs (error, warn, info, debug)
LOG_LEVEL=debug

# =============================================================================
# 🚀 CONFIGURATION PRODUCTION
# =============================================================================

# URL de production de l'API
PROD_API_URL=https://api.ndewa-360.com

# URL de production de l'application
PROD_APP_URL=https://ndewa-360.com

# Clé publique Stripe de production
PROD_STRIPE_PUBLIC_KEY=pk_live_VOTRE_CLE_PUBLIQUE_PRODUCTION

# =============================================================================
# 📊 CONFIGURATION MONITORING
# =============================================================================

# Activer le monitoring des erreurs
ENABLE_ERROR_MONITORING=true

# Activer les métriques de performance
ENABLE_PERFORMANCE_MONITORING=true

# =============================================================================
# 🔐 NOTES DE SÉCURITÉ
# =============================================================================

# 1. Révoquer immédiatement l'ancienne clé Stripe exposée
# 2. Générer de nouvelles clés pour tous les services
# 3. Utiliser des secrets managers en production (AWS Secrets Manager, etc.)
# 4. Activer la rotation automatique des clés
# 5. Monitorer l'utilisation des clés API

# =============================================================================
# 📝 INSTRUCTIONS D'UTILISATION
# =============================================================================

# 1. Copiez ce fichier: cp .env.example .env
# 2. Remplissez les valeurs appropriées
# 3. Vérifiez que .env est dans .gitignore
# 4. Redémarrez l'application après modification
