<!-- Template de test simplifié -->
<div style="padding: 20px; background: white; min-height: 100vh;">
  <h2>🔍 Page de Recherche Mobile</h2>
  <p>Composant chargé avec succès !</p>
  
  <!-- Test de recherche simple -->
  <ion-searchbar 
    placeholder="Rechercher..."
    [formControl]="searchControl">
  </ion-searchbar>
  
  <div style="margin-top: 20px;">
    <p>Ville actuelle: {{ currentCity || 'Non définie' }}</p>
    <p>Nombre de résultats: {{ searchResults?.length || 0 }}</p>
    <p>Chargement: {{ (isLoading$ | async) ? 'Oui' : 'Non' }}</p>
  </div>
  
  <!-- Test de boutons -->
  <div style="margin-top: 20px;">
    <ion-button (click)="performDefaultSearch()" fill="outline">
      Test Recherche Bangangté
    </ion-button>
  </div>
</div>
